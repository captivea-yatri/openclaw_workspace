<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_roles" model="ir.ui.view">
        <field name="name">product.template.form.inherit.roles</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='invoicing']" position="replace">
                <page string="Accounting" name="invoicing"
                      groups="account.group_account_readonly,account.group_account_invoice,access_rights_management.role_management_control,access_rights_management.role_administrative_responsible,access_rights_management.role_administrative">
                    <group name="properties"
                           groups="account.group_account_readonly,account.group_account_invoice,access_rights_management.role_management_control,access_rights_management.role_administrative_responsible,access_rights_management.role_administrative">
                        <group string="Receivables">
                            <field name="property_account_income_id"
                                   groups="account.group_account_readonly,account.group_account_invoice,access_rights_management.role_management_control,access_rights_management.role_administrative_responsible,access_rights_management.role_administrative"/>
                        </group>
                        <group string="Payables" name="payables">
                            <field name="property_account_expense_id"
                                   groups="account.group_account_readonly,account.group_account_invoice,access_rights_management.role_management_control,access_rights_management.role_administrative_responsible,access_rights_management.role_administrative"/>
                        </group>
                    </group>
                    <group name="accounting"
                           groups="account.group_account_readonly,account.group_account_invoice,access_rights_management.role_management_control,access_rights_management.role_administrative_responsible,access_rights_management.role_administrative"/>
                </page>
            </xpath>
        </field>
    </record>

    <record id="product_template_form_view_sale_order_button_roles" model="ir.ui.view">
        <field name="name">product.template.sale.order.button.roles</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="sale.product_template_form_view_sale_order_button"/>
        <field name="arch" type="xml">
            <button name="action_view_sales" position="attributes">
                <attribute name="groups">sales_team.group_sale_salesman,access_rights_management.role_management_control,access_rights_management.role_administrative_responsible,access_rights_management.role_administrative,access_rights_management.role_vps,access_rights_management.role_vp_of_sales,access_rights_management.role_ceo,access_rights_management.role_cfo,access_rights_management.role_cfo_for_his_company</attribute>
            </button>
        </field>
    </record>

    <record id="cap_product_pricelist_item_tree_inherit_roles" model="ir.ui.view">
        <field name="name">cap.product.pricelist.item.tree.inherit.product.role</field>
        <field name="model">product.pricelist.item</field>
        <field name="inherit_id" ref="product.product_pricelist_item_tree_view_from_product"/>
        <field name="arch" type="xml">
            <field name="pricelist_id" position="replace">
                <field name="pricelist_id" string="Pricelist" options="{'no_create_edit':1, 'no_open': 1}" groups="access_rights_management.role_president,access_rights_management.role_cfo,access_rights_management.role_cfo_for_his_company"/>
            </field>
            <field name="pricelist_id" position="after">
                <field name="pricelist_id" readonly="1" string="Pricelist" options="{'no_create_edit':1, 'no_open': 1}" groups="!access_rights_management.role_president,!access_rights_management.role_cfo,!access_rights_management.role_cfo_for_his_company"/>
            </field>
            <field name="min_quantity" position="replace">
                <field name="min_quantity" colspan="4" groups="access_rights_management.role_president,access_rights_management.role_cfo,access_rights_management.role_cfo_for_his_company"/>
            </field>
            <field name="min_quantity" position="after">
                <field name="min_quantity" readonly="1" colspan="4" groups="!access_rights_management.role_president,!access_rights_management.role_cfo,!access_rights_management.role_cfo_for_his_company"/>
            </field>
            <field name="fixed_price" position="replace">
                <field name="fixed_price" widget="monetary" string="Price" options="{'currency_field': 'currency_id', 'field_digits': True}" required="1" groups="access_rights_management.role_president,access_rights_management.role_cfo,access_rights_management.role_cfo_for_his_company"/>
            </field>
            <field name="fixed_price" position="after">
                <field name="fixed_price" string="Price" required='1' readonly="1" groups="!access_rights_management.role_president,!access_rights_management.role_cfo,!access_rights_management.role_cfo_for_his_company"/>
            </field>
            <field name="date_start" position="replace">
                <field name="date_start" optional="show" groups="access_rights_management.role_president,access_rights_management.role_cfo,access_rights_management.role_cfo_for_his_company"/>
            </field>
            <field name="date_start" position="after">
                <field name="date_start" optional="show" readonly="1" groups="!access_rights_management.role_president,!access_rights_management.role_cfo,!access_rights_management.role_cfo_for_his_company"/>
            </field>
            <field name="date_end" position="replace">
                <field name="date_end" optional="show" groups="access_rights_management.role_president,access_rights_management.role_cfo,access_rights_management.role_cfo_for_his_company"/>
            </field>
            <field name="date_end" position="after">
                <field name="date_end" optional="show" readonly="1" groups="!access_rights_management.role_president,!access_rights_management.role_cfo,!access_rights_management.role_cfo_for_his_company"/>
            </field>
            <field name="product_id" position="replace">
                <field name="product_id"
                    groups="access_rights_management.role_president,access_rights_management.role_cfo,access_rights_management.role_cfo_for_his_company"
                    readonly="context.get('active_model') == 'product.product'"
                    column_invisible="context.get('product_without_variants', False)"
                    required="applied_on == '0_product_variant'"
                    domain="['|', '|',
                    ('id', '=', context.get('default_product_id', 0)),
                    ('product_tmpl_id', '=', context.get('default_product_tmpl_id', 0)),
                    ('categ_id', '=', context.get('default_categ_id', 0)), '|', ('company_id', '=', company_id), ('company_id', '=', False)
                    ]"
                    placeholder="All variants"
                    options="{'no_create_edit':1, 'no_open': 1}"/>
            </field>
            <field name="product_id" position="after">
                <field name="product_id"
                    groups="!access_rights_management.role_president,!access_rights_management.role_cfo,!access_rights_management.role_cfo_for_his_company"
                    readonly="context.get('active_model') == 'product.product'"
                    column_invisible="context.get('product_without_variants', False)"
                    required="applied_on == '0_product_variant'"
                    domain="['|', '|',
                    ('id', '=', context.get('default_product_id', 0)),
                    ('product_tmpl_id', '=', context.get('default_product_tmpl_id', 0)),
                    ('categ_id', '=', context.get('default_categ_id', 0)), '|', ('company_id', '=', company_id), ('company_id', '=', False)
                    ]"
                    placeholder="All variants"
                    options="{'no_create_edit':1, 'no_open': 1}"/>
            </field>
            <field name="product_tmpl_id" position="replace">
                <field name="product_tmpl_id" column_invisible="context.get('active_model') != 'product.category'" required="applied_on == '1_product'" domain="[('categ_id', '=', context.get('default_categ_id', True)), '|', ('company_id', '=', company_id), ('company_id', '=', False)]" options="{'no_create_edit':1, 'no_open': 1}" groups="access_rights_management.role_president,access_rights_management.role_cfo,access_rights_management.role_cfo_for_his_company"/>
            </field>
            <field name="product_tmpl_id" position="after">
                <field name="product_tmpl_id"
                       column_invisible="context.get('active_model') != 'product.category'"
                       required="applied_on == '1_product'"
                       domain="[('categ_id', '=', context.get('default_categ_id', True)), '|', ('company_id', '=', company_id), ('company_id', '=', False)]"
                       options="{'no_create_edit':1, 'no_open': 1}"/>
            </field>
        </field>
    </record>

    <record id="product_template_form_variable_cost_view_inherit" model="ir.ui.view">
        <field name="name">product.template.form.inherit.roles</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='service_policy_div']" position="after">
                <field name="product_variable_cost"/>
            </xpath>
        </field>
    </record>

    <record id="product_product_form_variable_cost_view_inherit" model="ir.ui.view">
        <field name="name">product.product.form.inherit.roles</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='service_policy_div']" position="after">
                <field name="product_variable_cost"/>
            </xpath>
        </field>
    </record>
</odoo>
