<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_partner_form_crm_inherited_custom" model="ir.ui.view">
        <field name="name">view.res.partner.form.crm.inherited.custom</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="crm.view_partners_form_crm1"/>
        <field name="arch" type="xml">
            <button name="action_view_opportunity" position="replace">
                <button class="oe_stat_button o_res_partner_tip_opp" type="object"
                        name="action_view_opportunity"
                        icon="fa-star"
                        groups="access_rights_management.role_sales_hot,access_rights_management.role_marketing_manager,access_rights_management.role_email_manager,access_rights_management.role_community_manager,access_rights_management.role_sales_cold_team_director,access_rights_management.role_sales_cold_team_manager,access_rights_management.role_sales_cold,access_rights_management.show_sales,access_rights_management.role_vps,access_rights_management.role_cfo,access_rights_management.role_cfo_for_his_company"
                        context="{'default_partner_id': id, 'default_type':'opportunity'}">
                    <field string="Opportunities" name="opportunity_count" widget="statinfo"/>
                </button>
            </button>
        </field>
    </record>

    <record id="view_res_partner_form_sales_inherited_custom" model="ir.ui.view">
        <field name="name">view.res.partner.form.sale.inherited.custom</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="sale.res_partner_view_buttons"/>
        <field name="arch" type="xml">
            <button name="action_view_sale_order" position="replace">
                <button class="oe_stat_button" type="object" name="action_view_sale_order"
                    groups="access_rights_management.role_sales_hot,access_rights_management.show_sales,access_rights_management.role_management_control,access_rights_management.role_administrative_responsible,access_rights_management.role_administrative,access_rights_management.role_vps,access_rights_management.role_cfo,access_rights_management.role_cfo_for_his_company,access_rights_management.role_sales_cold,access_rights_management.role_sales_cold_team_manager,access_rights_management.role_sales_cold_team_director,access_rights_management.role_legal"
                    icon="fa-usd">
                    <field string="Sales" name="sale_order_count" widget="statinfo"/>
                </button>
            </button>
        </field>
    </record>

    <record id="view_res_partner_form_invoice_inherited_custom" model="ir.ui.view">
        <field name="name">view.res.partner.form.invoice.inherited.custom</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account.partner_view_buttons"/>
        <field name="arch" type="xml">
            <button name="action_view_partner_invoices" position="replace">
                <button type="object" class="oe_stat_button" icon="fa-pencil-square-o" name="action_view_partner_invoices"
                        groups="access_rights_management.role_sales_hot,account.group_account_invoice,account.group_account_readonly,access_rights_management.show_sales,access_rights_management.role_management_control,access_rights_management.role_administrative_responsible,access_rights_management.role_administrative,access_rights_management.role_vps,!access_rights_management.role_vp_of_marketing"
                        context="{'default_partner_id': id}">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_value">
                                <field name="currency_id" invisible="1"/>
                                <field name="total_invoiced" widget='monetary' options="{'currency_field': 'currency_id'}"/>
                            </span>
                            <span class="o_stat_text">Invoiced</span>
                        </div>
                    </button>
            </button>
        </field>
    </record>

    <record model="ir.ui.view" id="res_partner_view_inherit_sale_subscription_role">
        <field name="name">partner.view.button.subscriptions_count.role</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="sale_subscription.res_partner_view_inherit_sale_subscription"/>
        <field name="arch" type="xml">
            <button name="open_related_subscription" position="attributes">
                <attribute name="groups">access_rights_management.show_sales</attribute>
            </button>
        </field>
    </record>

