    <record id="timesheet_form_view_sale_order_smart_button" model="ir.ui.view">
        <field name="name">timesheet.form.view.sale.order.inherit</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_line_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet" position="before">
                <div class="oe_button_box" name="button_box">
                        <button name="action_sale_order_from_timesheet" type="object" class="oe_stat_button" icon="fa-dollar" invisible="not order_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Sales Order</span>
                            </div>
                        </button>
                    </div>
            </xpath>
        </field>
    </record>


    <record id="task_view_form_inherit_so_line_roles" model="ir.ui.view">
        <field name="name">project.task.form.soline</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="sale_timesheet.project_task_view_form_inherit_sale_timesheet"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='so_line'][1]" position="attributes">
                <attribute name="attrs">{'required': [('parent.allow_billable', '=', True)],
                    'invisible': [('id','=',1)], 'column_invisible': [('parent.allow_billable','=',False)]}
                </attribute>
            </xpath>
            <xpath expr="//field[@name='so_line'][2]" position="attributes">
                <attribute name="attrs">{'required': [('parent.allow_billable', '=', True)],
                    'invisible': [('id','=',1)], 'column_invisible': [('parent.allow_billable','=',False)]}
                </attribute>
            </xpath>
        </field>
    </record>

