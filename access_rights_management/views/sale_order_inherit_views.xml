    <record id="view_sale_order_form_inherit_project_ksc_custom" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="ksc_sale_project_extended.view_sale_order_form_inherit_project_ksc"/>
        <field name="arch" type="xml">
            <button name="%(ksc_sale_project_extended.action_link_po_so_view_form)d" position="replace">
                <button name="%(ksc_sale_project_extended.action_link_po_so_view_form)d"
                        string="Create/Link Project"
                        invisible="linked_project or state != 'sale'"
                        type="action"
                        groups="access_rights_management.group_create_delete_project,access_rights_management.role_vp_of_quality_and_knowledge,access_rights_management.role_president"
                        class="btn-primary"/>
            </button>
        </field>
    </record>

    <record id="view_sale_order_form_inherit_change_product" model="ir.ui.view">
        <field name="name">sale.order.form.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr='//field[@name="order_line"]/list/field[@name="company_id"]' position="after">
                <button name="action_open_wizard" type="object" string="Change Product"
                        invisible="state != 'sale'"
                        groups="access_rights_management.role_administrative_responsible,access_rights_management.role_cfo,access_rights_management.role_president"/>
            </xpath>
        </field>
    </record>

    <record id="view_sale_order_form_inherit_change_product_ksc" model="ir.ui.view">
        <field name="name">sale.order.form.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="ksc_sale_project_extended.view_sale_order_form_inherit_project_ksc"/>
        <field name="arch" type="xml">
            <xpath expr='//field[@name="order_line"][2]/list/field[@name="company_id"]' position="after">
                <button name="action_open_wizard"
                        string="Change Product" type="object"
                        invisible="state != 'sale'"
                        groups="access_rights_management.role_administrative_responsible,access_rights_management.role_cfo,access_rights_management.role_president"/>
            </xpath>
            <xpath expr="//page[@name='rate_increase_information']" position="attributes">
                <attribute name="groups">access_rights_management.role_president,access_rights_management.role_administrative_responsible,access_rights_management.role_sales_hot,access_rights_management.role_administrative,sales_team.group_sale_salesman</attribute>
            </xpath>
        </field>
    </record>

    <record id="sale.action_accrued_revenue_entry" model="ir.actions.act_window">
        <field name="groups_id"
               eval="[(4, ref('account.group_account_user')), (4, ref('access_rights_management.role_management_control')),
               (4, ref('access_rights_management.role_administrative_responsible')),
               (4, ref('access_rights_management.role_administrative'))]"/>
    </record>
</odoo>
