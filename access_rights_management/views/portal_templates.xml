<!--  ################################################ FOR SALE ORDER SIGN (PORTAL VIEW) ############################################    -->

    <template id="sale_order_portal_template_restricted_inherit"
              inherit_id="sale.sale_order_portal_template">
        <xpath expr="//t/t[@t-set='title']" position="replace">
            <t t-set="title">
                <h2 t-field="sale_order.amount_untaxed" data-id="total_amount" class="mb-0 text-break"/>
            </t>
        </xpath>
        <xpath expr='//div[hasclass("o_portal_sale_sidebar")]//t[1]//t[3]//div[1]//div[1]//a[1]' position="attributes">
            <attribute name="t-if">sale_order._has_to_be_signed() and sale_order._has_to_be_signed_only_by_cust()
            </attribute>
        </xpath>
        <xpath expr='//div[@id="quote_content"]//div[@name="sale_order_actions"]//t[1]' position="attributes">
            <attribute name="t-if">sale_order._has_to_be_signed() and sale_order._has_to_be_signed_only_by_cust()
            </attribute>
        </xpath>
    </template>
    
    <template id="portal_my_timesheets_inherit" inherit_id="hr_timesheet.portal_my_timesheets" name="Timesheet Portal - Add ID">
        <xpath expr="//thead/tr/th[.='Description']" position="before">
            <th>Task ID</th>
        </xpath>

        <xpath expr="//td[span[@t-esc='timesheet.name']]" position="before">
            <td> <span t-esc="timesheet.task_id.id or ''"/></td>
        </xpath>
        
        <xpath expr="//td[span[@t-esc='timesheet.name']]" position="attributes">
            <attribute name="style">white-space: normal; word-wrap: break-word;</attribute>
        </xpath>
    </template>

    <template id="portal_my_timesheets_inherit_colspan" inherit_id="sale_timesheet.portal_my_timesheets_inherit">
        <xpath expr="//t[@t-elif=&quot;groupby == 'so_line'&quot;]/th" position="attributes">
            <attribute name="colspan">6</attribute>
        </xpath>
    </template>
</odoo>
