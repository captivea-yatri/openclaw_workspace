<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="crm_lead_view_form_roles" model="ir.ui.view">
        <field name="name">crm.lead.roles</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/group/group[4]/field[@name='user_id']" position="after">
                <field name="x_studio_second_salesperson" string="Second Salesperson" options="{'no_open': True}" domain="[('share','=', False)]"/>
                <xpath expr="//group[@name='Misc']/field[@name='team_id']" position="move"/>
            </xpath>
        </field>
    </record>

</odoo>
