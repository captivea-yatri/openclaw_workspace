    <record id="project_view_kanban_inherit_project_roles" model="ir.ui.view">
        <field name="name">project.kanban.inherit.project.roles</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.project_view_kanban_inherit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@groups='project.group_project_user']" position="replace">
                <div role="menuitem"
                     groups="project.group_project_user,access_rights_management.role_management_control,access_rights_management.role_administrative_responsible,access_rights_management.role_administrative,access_rights_management.role_vps,access_rights_management.role_vp_of_sales">
                    <a name="project_update_all_action" type="object"
                       t-attf-context="{'active_id': #{record.id.raw_value} }">Dashboard
                    </a>
                </div>
            </xpath>
        </field>
    </record>

    <record model="ir.ui.view" id="project_project_view_form_roles">
        <field name="name">project.project.view.form.roles</field>
        <field name="model">project.project</field>
        <field name="priority">19</field>
        <field name="inherit_id" ref="ksc_project_go_live_maintainer.project_project_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='%(ksc_project_go_live_maintainer.action_view_project_glive_change_request)d']" position="replace">
                <button class="oe_stat_button" type="action"
                        name="%(ksc_project_go_live_maintainer.action_view_project_glive_change_request)d"
                        groups="!access_rights_management.role_vp_of_marketing"
                        string="Go-Live Change Req" icon="fa-tasks">
                </button>
            </xpath>
        </field>
    </record>

    <record id="edit_project_form_inherit_restrict_manual_timesheet_roles" model="ir.ui.view">
        <field name="name">project.project.form.restrict.manual.timesheet.roles</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="ksc_project_extended.edit_project_form_inherit_restrict_manual_timesheet"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='restricted_manual_timesheet']" position="replace">
                <div class="o_setting_box" id="restricted_manual_timesheet"
                     groups="access_rights_management.role_president,access_rights_management.role_vp_of_quality_and_knowledge">
                    <div class="o_setting_left_pane">
                        <field name="restrict_manual_timesheet"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label string="Restrict Timesheet" for="restrict_manual_timesheet"/>
                        <div class="text-muted" id="restrict_manual_timesheet_setting">
                            Restrict Manual Timesheet
                        </div>
                    </div>
                </div>
            </xpath>
            <xpath expr="//div[@id='restricted_manual_timesheet']" position="after">
                <div class="o_setting_box mt-4" colspan="2"
                     groups="!access_rights_management.role_president,!access_rights_management.role_vp_of_quality_and_knowledge">
                    <div class="o_setting_left_pane">
                        <field name="restrict_manual_timesheet" readonly="1"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label string="Restrict Timesheet" for="restrict_manual_timesheet"/>
                        <div class="text-muted" id="restrict_manual_timesheet_setting">
                            Restrict Manual Timesheet
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <record model="ir.ui.view" id="project_task_view_form_roles_18">
        <field name="name">project.task.view.form.roles18</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project_enterprise.project_task_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//label[@for='date_deadline']" position="replace"/>
        </field>
    </record>

    <record id="view_edit_project_inherit_form_visible_partner" model="ir.ui.view">
        <field name="name">project.project.view.inherit.partner</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="sale_project.view_edit_project_inherit_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="invisible">0</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_task_form_inherit_sale_project" model="ir.ui.view">
        <field name="name">project.task.form.inherit.sale.project</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="sale_project.view_task_tree2_inherit_sale_project"/>
        <field name="arch" type="xml">
            <xpath expr="(//field[@name='sale_line_id'])[1]" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="(//field[@name='sale_line_id'])[2]" position="replace">
                <field name="sale_line_id" optional="hide" options="{'no_open': True, 'no_create': True}"
                       domain="[('id', 'in', sale_order_line_ids), ('x_studio_service_tracking', '!=', 'no'), ('is_service', '=', True), ('is_expense', '=', False), ('state', 'in', ['sale', 'done'])]"
                       required="x_studio_project_contains_sale_order"/>
            </xpath>
        </field>
    </record>
</odoo>
