    <record id="project_project_view_kanban_inherit_sale_timesheet_so_button_roles" model="ir.ui.view">
        <field name="name">project.project.kanban.inherit.sale.timesheet.so.button_roles</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="sale_timesheet.project_project_view_kanban_inherit_sale_timesheet_so_button"/>
        <field name="arch" type="xml">
            <xpath expr='//div[@t-if="record.allow_billable.raw_value and record.sale_order_id.raw_value and record.pricing_type.raw_value != &apos;task_rate&apos;"]' position="replace">
                <div t-if="record.allow_billable.raw_value and record.sale_order_id.raw_value and record.pricing_type.raw_value != 'task_rate'"
                    role="menuitem"
                    groups="sales_team.group_sale_salesman_all_leads,access_rights_management.role_management_control,access_rights_management.role_administrative_responsible,access_rights_management.role_administrative,access_rights_management.role_vps,access_rights_management.role_cfo,access_rights_management.role_cfo_for_his_company,access_rights_management.role_vp_of_marketing">
                    <a name="action_view_sos" type="object">Sales Orders</a>
                </div>
            </xpath>
        </field>
    </record>

    <record id="edit_project_roles" model="ir.ui.view">
        <field name="name">project.view.form.roles</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr='//button[@name="action_open_share_project_wizard"]' position="replace">
                <button name="action_open_share_project_wizard" string="Share Project" type="object"
                        class="oe_highlight"
                        groups="project.group_project_manager,access_rights_management.role_vp_of_quality_and_knowledge,access_rights_management.role_cfo,access_rights_management.role_ceo,access_rights_management.role_vp_of_sales,access_rights_management.role_team_manager,access_rights_management.role_team_director,access_rights_management.role_operation,access_rights_management.role_operation_on_boarder"
                        invisible="privacy_visibility != 'portal'" context="{'default_access_mode': 'read'}"
                        data-hotkey="r"/>
            </xpath>
            <xpath expr='//page[@name="analytic"]' position="replace">
                <page name="analytic" string="Analytic"
                      groups="analytic.group_analytic_accounting,access_rights_management.role_management_control,access_rights_management.role_administrative_responsible,access_rights_management.role_administrative,access_rights_management.role_legal,access_rights_management.role_team_director,access_rights_management.role_vp_of_sales,access_rights_management.role_ceo,access_rights_management.role_vp_of_quality_and_knowledge">
                    <group>
                        <group>
                            <field name="account_id"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_project_kanban_roles" model="ir.ui.view">
        <field name="name">project.project.kanban.roles</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban"/>
        <field name="arch" type="xml">
            <xpath expr='//templates/t[1]/div[1]/div[1]/div[1]' position="attributes">
                <attribute name="class">col-12</attribute>
            </xpath>
            <xpath expr='//div[hasclass("o_kanban_manage_reporting")]/div[@name="task_analysis"]' position="replace">
                <div role="menuitem" name="task_analysis"
                     groups="project.group_project_user,access_rights_management.role_vps,access_rights_management.role_vp_of_sales">
                    <a name="action_view_tasks_analysis" type="object">Tasks Analysis</a>
                </div>
            </xpath>
            <xpath expr='//div[hasclass("o_kanban_manage_reporting")]/div[@name="project_burndown_menu"]'
                   position="replace">
                <div role="menuitem" name="project_burndown_menu"
                     groups="project.group_project_user,access_rights_management.role_vps,access_rights_management.role_vp_of_sales">
                    <a name="action_project_task_burndown_chart_report" type="object">Burndown Chart</a>
                </div>
            </xpath>
            <xpath expr='//div[hasclass("o_kanban_manage_reporting")]/h5' position="replace">
                <h5 role="menuitem" class="o_kanban_card_manage_title"
                    groups="project.group_project_user,access_rights_management.role_vps,access_rights_management.role_vp_of_sales">
                    <span>Reporting</span>
                </h5>
            </xpath>
            <xpath expr='//div[hasclass("o_kanban_card_manage_settings")]/div[2]' position="replace">
                <div role="menuitem" class="col-6"
                     groups="project.group_project_manager,access_rights_management.role_vps,access_rights_management.role_vp_of_sales,access_rights_management.role_ceo,access_rights_management.role_vp_of_quality_and_knowledge,access_rights_management.role_drh,access_rights_management.role_cfo,access_rights_management.role_cfo_for_his_company,access_rights_management.role_vp_of_marketing">

                    <a t-if="record.privacy_visibility.raw_value == 'portal'" class="dropdown-item" role="menuitem"
                       name="action_open_share_project_wizard" type="object">Share Project
                    </a>

                    <a class="dropdown-item" role="menuitem" name="copy" type="object">Duplicate</a>
                    <a class="dropdown-item" role="menuitem" type="open">Settings</a>
                </div>
            </xpath>
            <xpath expr='//div[hasclass("o_kanban_card_manage_settings")]/div[3]' position="replace">
                <div class="col-12 ps-0"
                     groups="!project.group_project_manager,!access_rights_management.role_vps,!access_rights_management.role_vp_of_sales,!access_rights_management.role_ceo,!access_rights_management.role_vp_of_quality_and_knowledge,!access_rights_management.role_drh,!access_rights_management.role_cfo,!access_rights_management.role_cfo_for_his_company,!access_rights_management.role_vp_of_marketing">
                    <div role="menuitem" class="w-100">
                        <a class="dropdown-item mx-0" role="menuitem" type="open">View</a>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

