<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_sale_order_access_role" model="ir.ui.view">
        <field name="name">project.sale.order.inherit.form.role</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="sale_project.view_sale_project_inherit_form"/>
        <field name="arch" type="xml">
            <field name="sale_order_id" position="attributes">
                <attribute name="groups">access_rights_management.role_sales_hot,sales_team.group_sale_salesman_all_leads,access_rights_management.role_management_control,access_rights_management.role_administrative_responsible,access_rights_management.role_administrative,access_rights_management.role_vps</attribute>
            </field>
            <button name="action_view_so" position="replace">
                <button class="oe_stat_button"
                        type="object" name="action_view_so" icon="fa-dollar"
                        invisible="not sale_order_id"
                        groups="access_rights_management.role_sales_hot,sales_team.group_sale_salesman_all_leads,access_rights_management.role_management_control,access_rights_management.role_administrative_responsible,access_rights_management.role_administrative,access_rights_management.role_vps">
                        <div class="o_stat_info">
                            <span class="o_stat_text">Sales Order</span>
                        </div>
                </button>
            </button>
            <xpath expr="//label[@for='sale_line_id']" position="replace">
            </xpath>
            <xpath expr="//div[@name='sale_line_div']" position="replace">
            </xpath>
        </field>
    </record>

