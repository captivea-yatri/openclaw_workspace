<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_credit_card_no_form" model="ir.ui.view">
        <field name="name">purchase.order.ccno.form</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='other_info']" position="inside">
                <field name="credit_card_no"
                       groups="!access_rights_management.role_cfo,!access_rights_management.role_president,!access_rights_management.role_cfo_for_his_company"
                       readonly="1"/>
            </xpath>
            <xpath expr="//group[@name='other_info']" position="inside">
                <field name="credit_card_no"
                       groups="access_rights_management.role_cfo,access_rights_management.role_president,access_rights_management.role_cfo_for_his_company"/>
            </xpath>
            <xpath expr="//button[@name='button_confirm'][1]" position="attributes">
                <attribute name="groups">purchase.group_purchase_user</attribute>
            </xpath>
            <xpath expr="//button[@name='button_confirm'][2]" position="attributes">
                <attribute name="groups">purchase.group_purchase_user</attribute>
            </xpath>
        </field>
    </record>
</odoo>
