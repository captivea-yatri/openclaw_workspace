<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="change_product_wizard_form_view" model="ir.ui.view">
        <field name="name">change.product.wizard.form.view</field>
        <field name="model">change.product.wizard</field>
        <field name="arch" type="xml">
            <form string="product">
                <group>
                    <group>
                        <field name="sale_line_id" invisible="1"/>
                        <field name="is_subscription" invisible="1"/>
                        <field name="product_id" domain="[('recurring_invoice','=',is_subscription)]"/>
                    </group>
                </group>
                <footer>
                    <button name="change_product" string="Submit" type="object"
                            class="btn-primary"/>
                    <button special="cancel" data-hotkey="z" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_change_product_wizard" model="ir.actions.act_window">
        <field name="name">Change Product</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">change.product.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="change_product_wizard_form_view"/>
        <field name="target">new</field>
    </record>

</odoo>
