<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="cap_view_hr_employee_form" model="ir.ui.view">
        <field name="name">cap.view.hr.employee.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority">16</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook/page[@name='hr_settings']/group/group[@name='identification_group']"
                   position="inside">
                <label for="global_quality_score" string="Global Quality Score"/>
                <div class="oe_inline" name="global_quality_score">
                    <field name="global_quality_score" class="oe_inline" readonly="1"/>%
                </div>
                <field name="quality_score_message" readonly="1"/>
                <field name="exclude_from_timesheet_quality_control"/>
            </xpath>
        </field>
    </record>

    <record id="emp_form_view_quality_issue_log" model="ir.ui.view">
        <field name="name">emp.quality.issue.log.form.view</field>
        <field name="model">quality.issue.log</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <header>
                    <button name="ask_for_review" type="object" string="Ask For Review"
                            invisible="state != 'enabled' or log_type == 'warning'"/>
                    <button name="refuse_review" type="object" string="Refuse Review"
                            invisible="not is_valid_user or state != 'reviewing'" class="btn btn-primary"/>
                    <button name="accept_review" type="object" string="Accept and disabled quality issue"
                            invisible="not is_valid_user or state != 'reviewing'" class="btn btn-primary"/>
                    <field name="state" widget="statusbar" options="{'clickable': 0}" readonly="1"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" name="action_open_approval_req" icon="fa-bullseye" type="object" invisible="state == 'warning'">
                            <span class="o_stat_text">Approval Request</span>
                        </button>
                    </div>
                    <group>
                        <field name="is_valid_user" invisible="1"/>
                        <field name="logged_date" required="1"/>
                        <field name="employee_id" required="1"/>
                        <field name="project_id"/>
                        <field name="description" required="1"/>
                        <label for="score_impact" string="Score Impact"/>
                        <div class="oe_inline" name="score_impact">
                            <field name="score_impact" class="oe_inline" required="1"/>%
                        </div>
                        <field name="quality_issue_type"/>
                    </group>
                </sheet>
                <div class="o_attachment_preview"/>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="emp_tree_view_quality_issue_log" model="ir.ui.view">
        <field name="name">emp.quality.issue.log.tree.view</field>
        <field name="model">quality.issue.log</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="logged_date"/>
                <field name="log_type"/>
                <field name="state"/>
                <field name="employee_id"/>
                <field name="project_id"/>
                <field name="description"/>
                <field name="score_impact" sum="Total" string="Score Impact(%)"/>
                <field name="quality_issue_type"/>
            </list>
        </field>
    </record>

    <record id="emp_action_emp_quality_issue_log" model="ir.actions.act_window">
        <field name="name">Quality Issue Log</field>
        <field name="res_model">quality.issue.log</field>
        <field name="view_mode">list,form</field>
        <field name="domain">['|', ('employee_id.user_id', '=', uid), ('employee_id.parent_id.user_id', '=', uid)]</field>
        <field name="context">{'default_employee_id.user_id': uid,
            'tree_view_ref': 'cap_quality_issue_log.emp_tree_view_quality_issue_log',
            'form_view_ref': 'cap_quality_issue_log.emp_form_view_quality_issue_log'}
        </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Quality Issue Log Found!
            </p>
        </field>
    </record>

    <menuitem id="menu_emp_quality_issue_log"
              name="My Quality Issue Log"
              action="emp_action_emp_quality_issue_log"
              parent="cap_quality_issue_log.menu_employee_performance_quality"
              sequence="0"/>
</odoo>
