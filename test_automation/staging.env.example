# Copy to staging.env and fill in (staging.env is gitignored — never commit secrets).
# Usage:
#   set -a && source test_automation/staging.env && set +a
#   python3 test_automation/run_test_suite.py --all --mode smoke --load-staging-env

ODOO_URL=http://localhost:1919/
ODOO_DB=odoo19_captivea2
ODOO_USER=admin1
ODOO_PASSWORD=change-me
ODOO_RPC=jsonrpc

# Optional: subprocess timeout per bundled script (seconds)
ODOO_SCRIPT_TIMEOUT=600

# Optional: allow known staging hosts even if name contains "prod" substring
# STAGING_QA_ALLOWED_HOSTS=localhost,staging,vps-

# Optional: extra production hints (comma-separated substrings)
# STAGING_QA_PROD_HINTS=my-prod-db

# Never set on staging unless you know what you are doing:
# STAGING_QA_ALLOW_PRODUCTION=1

# Live AI (connect_mistral_ai matrix)
# MISTRAL_API_KEY=
