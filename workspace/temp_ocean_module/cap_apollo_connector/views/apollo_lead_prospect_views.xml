<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="apollo_lead_prospect_form_view" model="ir.ui.view">
        <field name="name">apollo.lead.prospect.form</field>
        <field name="model">apollo.lead.prospect</field>
        <field name="arch" type="xml">
            <form string="Apollo Lead Prospecting">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        <p>
                            <strong>Search</strong> Apollo's database (free, no credits),
                            <strong>Enrich</strong> selected prospects (uses credits),
                            then <strong>Create CRM Leads</strong> in Odoo.
                        </p>
                        <p>Bulk enrichment handles up to 10 prospects per API call.</p>
                    </div>
                    <group>
                        <group string="Search Filters">
                            <field name="instance_id"/>
                            <field name="person_titles" placeholder="CEO, Sales Director"/>
                            <field name="person_locations" placeholder="California, US"/>
                            <field name="organization_locations" placeholder="United States"/>
                            <field name="organization_domains" placeholder="apollo.io, microsoft.com"/>
                            <field name="person_seniorities" placeholder="director, manager"/>
                        </group>
                        <group string="Pagination &amp; Options">
                            <field name="per_page"/>
                            <field name="page"/>
                            <field name="total_entries" invisible="not result_message"/>
                            <field name="result_message" invisible="not result_message"/>
                            <field name="reveal_personal_emails"/>
                            <field name="reveal_phone_number"/>
                        </group>
                    </group>
                    <group invisible="not line_ids">
                        <field name="line_ids" nolabel="1" colspan="2">
                            <list editable="top" create="false" delete="false">
                                <field name="selected"
                                       widget="boolean_toggle"
                                       readonly="state in ('existing_lead', 'lead_created')"/>
                                <field name="display_name" readonly="1"/>
                                <field name="title" readonly="1"/>
                                <field name="organization_name" readonly="1"/>
                                <field name="enriched_email" readonly="1"/>
                                <field name="enriched_phone" readonly="1"/>
                                <field name="state" widget="badge" readonly="1"
                                       decoration-success="state in ('enriched', 'lead_created')"
                                       decoration-warning="state == 'existing_lead'"
                                       decoration-danger="state == 'error'"
                                       decoration-muted="state == 'search'"/>
                                <field name="apollo_person_id" readonly="1"/>
                                <button name="action_open_crm_lead"
                                        type="object"
                                        string="Open Lead"
                                        class="btn-link"
                                        invisible="not crm_lead_id and not existing_lead_id"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button name="action_search_prospects"
                            string="Search"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_enrich_selected"
                            string="Enrich Selected"
                            type="object"
                            class="btn-secondary"
                            invisible="not line_ids"/>
                    <button name="action_create_crm_leads"
                            string="Create CRM Leads"
                            type="object"
                            class="btn-secondary"
                            invisible="not line_ids"/>
                    <button name="action_enrich_and_create_leads"
                            string="Enrich &amp; Create Leads"
                            type="object"
                            class="oe_highlight"
                            invisible="not line_ids"/>
                    <button string="Close" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_apollo_lead_prospect" model="ir.actions.act_window">
        <field name="name">Lead Prospecting</field>
        <field name="res_model">apollo.lead.prospect</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_crm_apollo_lead_prospect"
              name="Apollo Prospecting"
              parent="crm.crm_menu_root"
              action="action_apollo_lead_prospect"
              sequence="6"
              groups="sales_team.group_sale_salesman"/>
</odoo>
