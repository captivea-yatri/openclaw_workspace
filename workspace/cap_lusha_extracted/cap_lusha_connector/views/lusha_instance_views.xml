<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="lusha_instance_tree_view" model="ir.ui.view">
        <field name="name">lusha.instance.tree</field>
        <field name="model">lusha.instance</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="connection_status" widget="badge"
                       decoration-success="connection_status == 'connected'"
                       decoration-danger="connection_status == 'failed'"
                       decoration-muted="connection_status == 'unknown'"/>
                <field name="credit_remaining"/>
                <field name="last_connection_test"/>
            </list>
        </field>
    </record>

    <record id="lusha_instance_form_view" model="ir.ui.view">
        <field name="name">lusha.instance.form</field>
        <field name="model">lusha.instance</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_test_connection"
                            string="Test Connection"
                            type="object"
                            class="oe_highlight"/>
                    <button name="action_open_people_enrichment"
                            string="Contact Enrichment"
                            type="object"
                            class="btn-secondary"/>
                    <button name="action_open_company_enrichment"
                            string="Company Enrichment"
                            type="object"
                            class="btn-secondary"/>
                    <button name="action_open_lead_prospect"
                            string="Lead Prospecting"
                            type="object"
                            class="btn-secondary"/>
                    
                </header>
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Lusha Production"/>
                        </h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="connection_status" readonly="1"/>
                            <field name="last_connection_test" readonly="1"/>
                            <field name="connection_message" readonly="1" invisible="not connection_message"/>
                            <field name="plan_category" readonly="1"/>
                        </group>
                        <group string="Credits">
                            <field name="credit_total" readonly="1"/>
                            <field name="credit_used" readonly="1"/>
                            <field name="credit_remaining" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Authentication">
                            <field name="api_base_url" readonly="1"/>
                            <field name="api_key" password="True"/>
                        </group>
                        
                    </group>
                    <group>
                        <div class="alert alert-info" role="alert">
                            <p>
                                Lusha API V3 authenticates REST requests with an API key sent in the
                                <code>api_key</code> request header.
                            </p>
                            <p>
                                Generate a key in the
                                <a href="https://dashboard.lusha.com/enrich/api" target="_blank">Lusha dashboard</a>.
                            </p>
                            
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lusha_instance" model="ir.actions.act_window">
        <field name="name">Lusha Instances</field>
        <field name="res_model">lusha.instance</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Lusha instance and connect Odoo with your API key.
            </p>
        </field>
    </record>

    <menuitem id="lusha_main_menu"
              name="Lusha"
              sequence="46"/>

    <menuitem id="menu_lusha_lead_prospect"
              name="Lead Prospecting"
              parent="lusha_main_menu"
              action="action_lusha_lead_prospect"
              sequence="15"/>

    <menuitem id="menu_lusha_people_enrichment"
              name="Contact Enrichment"
              parent="lusha_main_menu"
              action="action_lusha_people_enrichment"
              sequence="20"/>

    <menuitem id="menu_lusha_company_enrichment"
              name="Company Enrichment"
              parent="lusha_main_menu"
              action="action_lusha_company_enrichment"
              sequence="25"/>

    <menuitem id="menu_lusha_instance"
              name="Configuration"
              parent="lusha_main_menu"
              action="action_lusha_instance"
              sequence="10"
              groups="base.group_system"/>
</odoo>
