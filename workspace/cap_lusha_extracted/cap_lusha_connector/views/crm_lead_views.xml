<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_crm_lead_form_lusha" model="ir.ui.view">
        <field name="name">crm.lead.form.lusha</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='extra']" position="inside">
                <group string="Lusha">
                    <field name="lusha_contact_id" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
