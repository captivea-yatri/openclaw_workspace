<odoo>
    <data noupdate="1">
        <record id="ir_cron_ocean_sync_leads" model="ir.cron">
            <field name="name">Sync Odoo Leads to Ocean.io</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">model.with_user(1).sudo()._cron_sync_all_leads()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall">False</field>
        </record>
        <record id="ir_cron_ocean_sync_contacts" model="ir.cron">
            <field name="name">Sync Odoo Contacts to Ocean.io</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model.with_user(1).sudo()._cron_sync_all_contacts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall">False</field>
        </record>
    </data>
</odoo>