# Staging Odoo target for cap_qa_platform QA runs.
# Usage: set -a && source staging.env && set +a

ODOO_URL=https://staging-odoo19-captivea.odoo.com/
ODOO_DB=captivea-staging-odoo19-33645016
ODOO_USER=yatri.modi@captivea.com
ODOO_PASSWORD=a
ODOO_RPC=jsonrpc

# Allow Odoo SaaS staging host (matches CAP_QA prod safety hints for odoo.com)
CAP_QA_ALLOWED_HOSTS=staging-odoo19-captivea.odoo.com

# UI tests use cap_qa_tester after backend assigns role
CAP_QA_UI_HEADLESS=1

# Ocean.io lead enrichment scenario search domain (optional)
CAP_QA_OCEAN_SEARCH_DOMAIN=odoo.com

# Never on production unless intentional:
# CAP_QA_ALLOW_PRODUCTION=1
